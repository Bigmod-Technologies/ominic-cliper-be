# Copy this file to ".env" and fill values.
# Never commit the real ".env" file.
#
# Sections:
# - Docker / production image: build args and container runtime (Dockerfile, docker-compose.prod.yml)
# - Django: app settings (see DJANGO_ENV)
# - Database: required when DJANGO_ENV=prod
# - S3 / iDrive E2: media when DJANGO_ENV=prod

# -----------------------------------------------------------------------------
# Docker / production container (Dockerfile + docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# Port Daphne listens on (EXPOSE, host mapping, and build.sh CMD use this).
APP_PORT=8000

# Non-root user inside the image; build.sh uses these to chown the static volume.
# Match your host UID/GID if you bind-mount ./static and hit permission issues.
USER_UID=1000
USER_GID=1000

# Set to 1 to skip migrate and collectstatic on container start (e.g. debugging).
SKIP_MIGRATIONS=

# -----------------------------------------------------------------------------
# Settings selection
# -----------------------------------------------------------------------------
# - DJANGO_ENV=dev  -> Omnic_Clipper/settings/dev.py (DEBUG=True, sqlite, local media)
# - DJANGO_ENV=prod -> Omnic_Clipper/settings/prod.py (DEBUG=False, postgres, S3 media)
DJANGO_ENV=dev

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Used in both dev/prod. In prod, use a long random secret.
SECRET_KEY=replace-with-a-long-random-secret

# Comma-separated hosts. Examples:
# - ALLOWED_HOSTS=localhost,127.0.0.1
# - ALLOWED_HOSTS=api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins (comma-separated)
# Must include scheme (http/https). Example:
# CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://app.example.com
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Database (used when DJANGO_ENV=prod)
# -----------------------------------------------------------------------------
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your_db_host
DB_PORT=5432

# -----------------------------------------------------------------------------
# S3 / iDrive E2 (used for MEDIA when DJANGO_ENV=prod)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name

# If you provide host-only (no scheme), the app will normalize it to https://<value>
# Examples:
# - AWS_S3_ENDPOINT_URL=s3.us-west-1.idrivee2.com
# - AWS_S3_ENDPOINT_URL=https://s3.us-west-1.idrivee2.com
AWS_S3_ENDPOINT_URL=s3.us-west-1.idrivee2.com
AWS_S3_REGION_NAME=us-west-1

# Optional (only needed if you use a custom domain / CDN for bucket URLs)
AWS_S3_CUSTOM_DOMAIN=

# Optional folder prefix inside the bucket
AWS_LOCATION_MEDIA=media
